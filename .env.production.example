# Production environment (Cloud Run + Cloud SQL). Store these in Secret Manager,
# NOT in the image. BETTER_AUTH_URL must be the live domain.

# Cloud SQL via the Cloud Run socket (CONNECTION_NAME = PROJECT:REGION:INSTANCE)
DATABASE_URL="postgresql://a6ko:DB_PASSWORD@localhost/a6ko?host=/cloudsql/PROJECT:REGION:INSTANCE"

BETTER_AUTH_SECRET="GENERATE_A_NEW_LONG_RANDOM_STRING_FOR_PROD"
BETTER_AUTH_URL="https://studio.a6ko.com"

